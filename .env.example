# Copy to .env and fill in. NEVER commit real secrets.

# --- Maps SERP collection (production ranking source) ---
# DataForSEO — https://dataforseo.com/  (Google Maps live/advanced endpoint)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# --- Cloudflare Pages deploy ---
# PREFERRED: a scoped API token with "Cloudflare Pages: Edit" permission.
#   Create at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
# The account to deploy into (Seomarketer2011 = 44799b719f2192a9f066f425aaff3106).
CLOUDFLARE_ACCOUNT_ID=

# AVOID in production: the Global API Key grants full account control and cannot
# be scoped or cleanly revoked. Only use if you have no alternative.
# CLOUDFLARE_EMAIL=
# CLOUDFLARE_API_KEY=
